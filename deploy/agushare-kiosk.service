[Unit]
Description=Agushare Kiosk Display
After=network-online.target agushare-backend.service
Wants=network-online.target

[Service]
Type=simple
User=root
ExecStart=/root/agushare/deploy/kiosk.sh
Restart=always
RestartSec=3
Environment=DISPLAY=:0
Environment=WEBKIT_DISABLE_COMPOSITING_MODE=1
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
